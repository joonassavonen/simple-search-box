# Anthropic API
ANTHROPIC_API_KEY=sk-ant-...

# App settings
SECRET_KEY=change-me-in-production-use-long-random-string
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# Database (SQLite path for MVP)
DATABASE_URL=sqlite:///./findai.db

# Widget base URL (where widget.js is served from)
WIDGET_BASE_URL=http://localhost:8000

# Rate limiting (searches per minute per site)
RATE_LIMIT_PER_MINUTE=30

# Crawler settings
CRAWLER_MAX_PAGES=500
CRAWLER_REQUEST_TIMEOUT=10
CRAWLER_DELAY_SECONDS=1
